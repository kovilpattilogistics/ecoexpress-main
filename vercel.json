{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "routes": [
        {
            "src": "/ecoexpress-water/assets/(.*)",
            "dest": "/ecoexpress-water/assets/$1"
        },
        {
            "src": "/ecoexpress-water/(.*)",
            "dest": "/ecoexpress-water/index.html"
        },
        {
            "src": "/water-delivery/assets/(.*)",
            "dest": "/ecoexpress-water/assets/$1"
        },
        {
            "src": "/water-delivery(.*)",
            "dest": "/ecoexpress-water/index.html"
        },
        {
            "src": "/ecoexpress-trip/assets/(.*)",
            "dest": "/ecoexpress-trip/assets/$1"
        },
        {
            "src": "/ecoexpress-trip/(.*)",
            "dest": "/ecoexpress-trip/index.html"
        },
        {
            "src": "/trip-calculator(.*)",
            "dest": "/ecoexpress-trip/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}